# إعدادات السيرفر
PORT=3000
NODE_ENV=development

# إعدادات MongoDB
MONGODB_URI=mongodb://localhost:27017/al-muraqib
# أو MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/al-muraqib?retryWrites=true&w=majority

# JWT Secret (غير هاد السر فالإنتاج)
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRE=7d

# إعدادات البلاغات
ALERT_COOLDOWN_MINUTES=10
MAX_ALERTS_PER_HOUR=3
PENALTY_DURATION_MINUTES=30

# إعدادات المسافة (متر)
NEARBY_DRIVERS_RADIUS=5000
ALERT_RADIUS=3000

# إعدادات التسجيلات
MAX_AUDIO_DURATION_SECONDS=60
AUDIO_RETENTION_MINUTES=30

# إعدادات الإشهار (اختياري)
ADS_ENABLED=true
